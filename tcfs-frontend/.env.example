# Frontend Environment Variables Template
# Copy this file to .env.local and update with your values

# ============================================
# BACKEND API CONFIGURATION
# ============================================
# Local Development
VITE_API_URL=http://localhost:3000

# Production (after deploying to Render)
# VITE_API_URL=https://tcfs-backend-xxxxx.onrender.com

# ============================================
# SOCKET.IO CONFIGURATION
# ============================================
# Local Development
VITE_SOCKET_URL=http://localhost:3000

# Production (after deploying to Render)
# VITE_SOCKET_URL=https://tcfs-backend-xxxxx.onrender.com

# ============================================
# OPTIONAL: FRONTEND URL
# ============================================
# Local Development
VITE_FRONTEND_URL=http://localhost:5173

# Production (after deploying to Vercel)
# VITE_FRONTEND_URL=https://your-project.vercel.app

# ============================================
# NOTES
# ============================================
# - For local development: Use localhost URLs
# - For production: Use your deployed URLs
# - Never commit .env.local to Git
# - .env.local is in .gitignore