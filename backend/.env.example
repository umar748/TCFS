# Environment Configuration
# Copy this file to .env and update with your values

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=production
PORT=10000

# ============================================
# DATABASE
# ============================================
# MongoDB Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/tcfs_db

# ============================================
# FRONTEND URL (for CORS)
# ============================================
CLIENT_URL=https://your-frontend.vercel.app

# Local Development URLs (auto-allowed in CORS)
# http://localhost:3000
# http://localhost:5173
# http://localhost:10000

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long

# ============================================
# EMAIL CONFIGURATION (Gmail)
# ============================================
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
# Note: Use Google App Password (not your main password)
# Steps: 
# 1. Enable 2FA on Google Account
# 2. Go to myaccount.google.com/apppasswords
# 3. Generate app-specific password for "Mail"
# 4. Use that password here

# ============================================
# AI SERVICE (OpenAI)
# ============================================
OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================================
# AI SERVICE (Google Generative AI)
# ============================================
GOOGLE_API_KEY=your_google_generative_ai_key_here

# ============================================
# OPTIONAL: LOGGING
# ============================================
LOG_LEVEL=info
